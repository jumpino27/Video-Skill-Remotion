# ─────────────────────────────────────────────────────────────────────────────
# API keys for the media skills (/video, /music, /image, /crop).
# Copy this file to ".env" and fill in your keys:  cp .env.example .env
#
# Where this file can live (first match wins, env vars always override files):
#   • the skill's own folder            (skills/<name>/.env)
#   • the shared skills folder          (e.g. ~/.claude/skills/.env)
#   • your user-global Claude folder     (~/.claude/.env)
#   • ~/Documents/.env                  (legacy fallback)
#   • any path you point SKILL_ENV_FILE / VIDEO_ENV_FILE at
# ─────────────────────────────────────────────────────────────────────────────

# ElevenLabs — used by /video (Eleven v3 voiceover) and /music (Eleven Music).
# Get one at https://elevenlabs.io  (Profile → API Keys)
ELEVEN_LABS=

# OpenAI — used by /video (whisper-1 word-level timestamps) and /image (gpt-image-2).
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Optional ────────────────────────────────────────────────────────────────

# Override the default /video voice without touching persona.json:
# VIDEO_VOICE_ID=eXO2dNYP4zo4oPWzuLta

# Legacy / fallback music providers (only if ElevenLabs Music is unavailable):
# SUNO_API=
# OPENROUTER_API_KEY=
